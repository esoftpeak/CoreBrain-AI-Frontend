# Copy this file to web/.env (Vite does NOT read .env.example)
#
# Supabase Dashboard → Project Settings → API Keys
# Use the Publishable key (sb_publishable_...) OR legacy anon key (eyJ...)

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key_here
VITE_APP_URL=http://localhost:7000
